{
  "name": "dynamical-weather-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Probabilistic weather forecast powered by dynamical.org GEFS ensemble data",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:accuracy && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/",
    "lint": "oxlint src/ --deny-warnings",
    "test": "vitest run --coverage && playwright test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "generate:accuracy": "tsx scripts/build-accuracy-grid.ts",
    "check": "npm run fmt:check && npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/proj4": "^2.5.6",
    "@vitest/coverage-v8": "^3.2.4",
    "hyparquet": "^1.25.1",
    "numcodecs": "^0.3.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.70.0"
  },
  "dependencies": {
    "proj4": "^2.20.4",
    "zarrita": "^0.6.1"
  }
}
