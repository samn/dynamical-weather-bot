{
  "name": "dynamical-weather-bot",
  "version": "1.0.0",
  "type": "module",
  "description": "Probabilistic weather forecast powered by dynamical.org GEFS ensemble data",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:accuracy && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/",
    "lint": "oxlint src/ --deny-warnings",
    "test": "vitest run --coverage && playwright test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "generate:accuracy": "tsx scripts/build-accuracy-grid.ts",
    "check": "npm run fmt:check && npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/proj4": "^2.5.6",
    "@vitest/coverage-v8": "^4.1.5",
    "hyparquet": "^1.25.6",
    "numcodecs": "^0.3.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "hyparquet-compressors": "^1.1.1",
    "icechunk-js": "^0.4.0",
    "proj4": "^2.20.8",
    "zarrita": "^0.7.3"
  }
}
